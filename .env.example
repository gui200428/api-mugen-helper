# Database (use ?sslmode=require in production)
DATABASE_URL="postgresql://user:password@localhost:5432/user_db?schema=public"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=""

# CORS — allowed origins (comma-separated)
CORS_ORIGIN="http://localhost:3001"

# Public origin of the main site (used to rewrite external links inside demos)
PUBLIC_ORIGIN="https://mugentecnologia.com"

# Admin seed — password must be 12+ chars with uppercase, digit, and special char
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME=""

# NODE_ENV="production"