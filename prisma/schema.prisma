generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String

  // Account lockout (H2)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]
  clients       Client[]       @relation("AdminClients")
  notes         Note[]         @relation("AdminNotes")
  folders       Folder[]       @relation("AdminFolders")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([expiresAt])
}

// ═══════════════════════════════════════════
// Client Management
// ═══════════════════════════════════════════

enum ClientStatus {
  PENDING        // Ainda não criou demo
  DEMO_ACTIVE    // Demo online
  DEMO_EXPIRED   // Demo expirou (7 dias)
  CONTACTED      // Email enviado
  CONVERTED      // Cliente aceitou
  REJECTED       // Cliente recusou
}

model Client {
  id            String       @id @default(uuid())
  name          String       // Nome do estabelecimento
  ownerName     String?      // Nome do proprietário
  email         String       // Email de contato
  phone         String?      // Telefone / WhatsApp
  website       String       // Site atual do cliente
  country       String?      // País
  language      String?      // Idioma
  negotiator    String?      // Negociador
  notes         String?      // Notas internas
  thumbnailUrl  String?      // URL of the thumbnail image
  status        ClientStatus @default(PENDING)

  // Admin responsável
  adminId       String?
  admin         Admin?       @relation("AdminClients", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  demoPages     DemoPage[]

  @@index([status])
  @@index([adminId])
}

model DemoPage {
  id            String   @id @default(uuid())
  slug          String   @unique   // URL slug (ex: "pizzaria-roma")
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  filePath      String             // Caminho no filesystem para os arquivos
  thumbnailUrl  String?            // URL of the thumbnail image
  isActive      Boolean  @default(true)
  expiresAt     DateTime           // Data de expiração (createdAt + 7 dias)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([expiresAt])
  @@index([clientId])
}

// ═══════════════════════════════════════════
// Portfolio Pages (sem cliente, sem expiração)
// ═══════════════════════════════════════════

model PortfolioPage {
  id          String   @id @default(uuid())
  slug        String   @unique   // URL slug (ex: "site-restaurante")
  title       String             // Título descritivo da página
  filePath    String             // Caminho no filesystem
  thumbnailUrl String?           // URL of the thumbnail image
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

// ═══════════════════════════════════════════
// Folders (Pastas para Anotações)
// ═══════════════════════════════════════════

model Folder {
  id          String   @id @default(uuid())
  name        String
  
  parentId    String?
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderHierarchy")

  adminId     String?
  admin       Admin?   @relation("AdminFolders", fields: [adminId], references: [id], onDelete: SetNull)

  notes       Note[]   @relation("FolderNotes")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentId])
  @@index([adminId])
}

// ═══════════════════════════════════════════
// Admin Notes (Rascunho)
// ═══════════════════════════════════════════

model Note {
  id          String   @id @default(uuid())
  title       String?
  content     String
  
  folderId    String?
  folder      Folder?  @relation("FolderNotes", fields: [folderId], references: [id], onDelete: Cascade)

  // Admin que criou a nota
  adminId     String?
  admin       Admin?   @relation("AdminNotes", fields: [adminId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([folderId])
  @@index([adminId])
}
